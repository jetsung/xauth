# 服务基础配置
PORT=3000
# 服务监听的地址 (可选，默认 0.0.0.0)
HOST=0.0.0.0
# 服务的外部访问地址 (可选，用于回调地址等)
# SERVER_URL=http://localhost:3000
DEBUG=false

# GitHub
GITHUB_ID=
GITHUB_SECRET=

# Google
GOOGLE_ID=
GOOGLE_SECRET=

# X (Twitter)
X_ID=
X_SECRET=
# TWITTER_ID=
# TWITTER_SECRET=

# 微博
WEIBO_ID=
WEIBO_SECRET=

# QQ
QQ_ID=
QQ_SECRET=

# 华为
HUAWEI_ID=
HUAWEI_SECRET=

# OIDC
OIDC_ID=
OIDC_SECRET=
OIDC_ISSUER=https://accounts.google.com
# OIDC_SCOPES=openid profile email

# 通用覆盖示例 (可选)
# GITHUB_SCOPES=user:email
# GOOGLE_AUTH_URL=
